<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net7.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <Title>LibGDXSharp</Title>
        <AssemblyVersion></AssemblyVersion>
        <NeutralLanguage></NeutralLanguage>
        <Authors>Richard Ikin</Authors>
        <Description>A C# Conversion of the Java LibGDX 2D/3D Game development framework.</Description>
        <RepositoryUrl>https://github.com/biffbaff64/LibGDXSharp</RepositoryUrl>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <Optimize>True</Optimize>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="JetBrains.Annotations" Version="2022.3.1" />
        <PackageReference Include="RestSharp" Version="110.0.0" />
        <PackageReference Include="SharpZipLib" Version="1.4.2" />
        <PackageReference Include="Silk.NET.Input.Glfw" Version="2.16.0" />
        <PackageReference Include="Silk.NET.OpenGLES" Version="2.16.0" />
        <PackageReference Include="Silk.NET.Windowing.Glfw" Version="2.16.0" />
        <PackageReference Include="System.Drawing.Common" Version="7.0.0" />
    </ItemGroup>

    <ItemGroup>
        <Folder Include="Core\Graphics\G3D\Attributes\" />
        <Folder Include="Core\Graphics\G3D\Decals\" />
        <Folder Include="Core\Graphics\G3D\Environment\" />
        <Folder Include="Core\Graphics\G3D\Loader\" />
        <Folder Include="Core\Graphics\G3D\Shaders\" />
        <Folder Include="Core\Graphics\GLUtils\FrameBufferWIP\" />
        <Folder Include="Core\Utils\Compression\Gzip\" />
        <Folder Include="Core\Utils\Json\" />
        <Folder Include="Core\Utils\Observers\" />
        <Folder Include="DeleteCandidates\" />
        <Folder Include="Resources\" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Update="LocalResources.resx">
            <Generator>ResXFileCodeGenerator</Generator>
            <LastGenOutput>LocalResources.Designer.cs</LastGenOutput>
        </EmbeddedResource>
        <EmbeddedResource Remove="GDXExtensions\**" />
        <EmbeddedResource Remove="GDXBackends\**" />
    </ItemGroup>

    <ItemGroup>
        <Compile Update="LocalResources.Designer.cs">
            <DesignTime>True</DesignTime>
            <AutoGen>True</AutoGen>
            <DependentUpon>LocalResources.resx</DependentUpon>
        </Compile>
        <Compile Remove="GDXExtensions\**" />
        <Compile Remove="GDXBackends\**" />
    </ItemGroup>

    <ItemGroup>
        <None Remove="GDXExtensions\**" />
        <None Remove="GDXBackends\**" />
    </ItemGroup>

</Project>
